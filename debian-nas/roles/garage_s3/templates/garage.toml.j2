metadata_dir = "{{ garage_metadata_dir }}"
data_dir = "{{ garage_data_dir }}"
metadata_snapshots_dir = "{{ garage_metadata_snapshots_dir }}"
metadata_fsync = {{ garage_metadata_fsync | bool | to_json }}
data_fsync = {{ garage_data_fsync | bool | to_json }}
disable_scrub = {{ garage_disable_scrub | bool | to_json }}
